# Copie este arquivo para .env e preencha suas chaves.
# NUNCA faça commit do arquivo .env.

GEMINI_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Identificadores dos modelos (ajuste se necessário)
GEMINI_MODEL=gemini-1.5-pro
OPENAI_MODEL=gpt-4o-mini
DEEPSEEK_MODEL=deepseek/deepseek-r1:free

# Número de repetições por combinação (artigo original: 5)
N_REPS=5

# Pausa entre chamadas em segundos (aumente se atingir limite de requisições)
SLEEP_SECONDS=2
